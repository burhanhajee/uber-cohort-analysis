# Rename this file to secrets.toml and fill in your Mailtrap credentials.
# NEVER commit secrets.toml to source control.
#
# Get credentials from: https://mailtrap.io -> Inboxes -> SMTP Settings

SMTP_HOST       = "sandbox.smtp.mailtrap.io"
SMTP_PORT       = "2525"
SMTP_USER       = "your-mailtrap-username-here"
SMTP_PASS       = "your-mailtrap-password-here"
OPERATOR_EMAIL  = "your-email@example.com"
